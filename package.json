{
	"name": "clairifai",
	"version": "0.1.5",
	"description": "CLI tool that processes meeting transcripts into engineer-ready tickets via a 4-stage pipeline",
	"type": "module",
	"files": [
		"dist"
	],
	"bin": {
		"clairifai": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js",
		"test:unit": "node --test dist/**/*.test.js",
		"test:snapshot": "node --test dist/tests/snapshot.test.js",
		"test:integration": "node --test dist/tests/integration.test.js"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"keywords": [
		"meeting",
		"transcript",
		"tickets",
		"claude",
		"ai"
	],
	"license": "VallySeed",
	"dependencies": {
		"@octokit/rest": "^21.1.0",
		"ink": "^5.1.0",
		"react": "^18.3.1",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^18.3.0",
		"typescript": "^5.7.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp"
		]
	}
}
